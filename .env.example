# Narcore environment — copy to .env.local and fill in as needed.
# Everything works in mock mode with NO values set (deterministic local vectors).

# --- Redis Stack (vector search) ---
REDIS_URL=redis://localhost:6379

# --- Embeddings (swappable; falls back to mock if unreachable) ---
# auto = try providers below, else mock | mock = force local mock | live = require a provider
EMBEDDING_MODE=auto
# Self-hosted llama.cpp sidecar (OpenAI-compatible POST /v1/embeddings)
EMBEDDING_API_URL=http://localhost:8080/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nomic-embed-text-v2-moe
EMBEDDING_DIM=768
# Optional hosted fallback (any OpenAI-compatible nomic endpoint)
NOMIC_API_URL=
NOMIC_API_KEY=

# --- Scoring ---
RISK_THRESHOLD=0.7
CORPUS_TTL_DAYS=14

# --- Ingest auth (optional shared secret for the scraper) ---
INGEST_API_KEY=

# --- Browserbase scraper (WT-D) ---
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
MOCK_FEED_URL=http://localhost:3000/feed

# --- Outreach LLM (optional; template fallback if unset) ---
ANTHROPIC_API_KEY=
OUTREACH_MODEL=claude-haiku-4-5-20251001
